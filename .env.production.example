# Copy to .env.production and run:
#   docker compose --env-file .env.production up --build

POSTGRES_DB=resumepilot
POSTGRES_USER=resumepilot
POSTGRES_PASSWORD=change-me-generate-a-long-random-password

AUTH_TRUSTED_PROXY_SECRET=change-me-generate-a-long-random-shared-secret
JOBCOPILOT_API_TOKEN=change-me-generate-a-long-random-openclaw-token

# Host ports for the local production-like stack. The containers still listen
# on 8000 and 3000 internally.
BACKEND_PORT=8050
FRONTEND_PORT=3050

# Local is acceptable only for a private single-user production-like stack.
# Use clerk or trusted_headers before opening the app to real users.
RESUMEPILOT_AUTH_PROVIDER=local
# This example keeps the private Docker demo working under NODE_ENV=production.
# Set false when RESUMEPILOT_AUTH_PROVIDER is clerk or trusted_headers.
RESUMEPILOT_ALLOW_LOCAL_AUTH_IN_PRODUCTION=true
DEV_USER_EXTERNAL_ID=local-production-user
DEV_USER_EMAIL=
DEV_USER_DISPLAY_NAME=Local Production User

# Clerk mode for public users.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

DATA_RETENTION_DAYS=30
ENABLE_JOB_BROWSER_FALLBACK=false

AGENT_WORKFLOW_MODE=deterministic_fallback
LLM_PROVIDER=vertex
VERTEX_PROJECT_ID=
VERTEX_REGION=global
LLM_MODEL=gemini-3.5-flash
CREWAI_LLM_MODEL=
