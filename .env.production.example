# Copy to .env.production and run:
#   docker compose --env-file .env.production up --build

POSTGRES_DB=resumepilot
POSTGRES_USER=resumepilot
POSTGRES_PASSWORD=change-me-generate-a-long-random-password

AUTH_TRUSTED_PROXY_SECRET=change-me-generate-a-long-random-shared-secret
JOBCOPILOT_API_TOKEN=change-me-generate-a-long-random-openclaw-token

# Host ports for the local production-like stack. The containers still listen
# on 8000 and 3000 internally.
BACKEND_PORT=8050
FRONTEND_PORT=3050
BACKEND_BIND_HOST=127.0.0.1
FRONTEND_BIND_HOST=127.0.0.1

# Public deployments must use clerk or trusted_headers. To run a private,
# loopback-only single-user stack, explicitly switch this to local and set the
# opt-in below to true.
RESUMEPILOT_AUTH_PROVIDER=clerk
RESUMEPILOT_ALLOW_LOCAL_AUTH_IN_PRODUCTION=false
DEV_USER_EXTERNAL_ID=local-production-user
DEV_USER_EMAIL=
DEV_USER_DISPLAY_NAME=Local Production User

# Clerk mode for public users. The publishable key is also passed into the
# frontend image build because NEXT_PUBLIC values are compiled into the client.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Required only for RESUMEPILOT_AUTH_PROVIDER=trusted_headers. Configure the
# same value in the identity-aware upstream proxy and strip inbound identity
# headers before that proxy signs and forwards them.
RESUMEPILOT_TRUSTED_HEADER_SECRET=
RESUMEPILOT_TRUSTED_HEADER_TTL_SECONDS=300

DATA_RETENTION_DAYS=30
ENABLE_JOB_BROWSER_FALLBACK=false
LATEX_COMPILE_TIMEOUT_SECONDS=20
LATEX_PDF_MAX_BYTES=5242880

AGENT_WORKFLOW_MODE=deterministic_fallback
LLM_PROVIDER=vertex
VERTEX_PROJECT_ID=
VERTEX_REGION=global
LLM_MODEL=gemini-3.5-flash
CREWAI_LLM_MODEL=

# The API only enqueues durable work in production. The Compose worker leases
# jobs from PostgreSQL and applies retry/cancellation/dead-letter semantics.
WORKFLOW_INLINE_EXECUTION=false
WORKFLOW_WORKER_POLL_SECONDS=1
WORKFLOW_JOB_LEASE_SECONDS=180
WORKFLOW_JOB_MAX_ATTEMPTS=3
USAGE_RESERVATION_TTL_SECONDS=900
