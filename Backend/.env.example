APP_ENV=development
APP_DEBUG=false
DATABASE_URL=sqlite:///./.local/data/resumepilot.db
RESUMEPILOT_DATA_DIR=./.local/data
AUTO_CREATE_DB_SCHEMA=true
REQUIRE_DB_MIGRATIONS=false

JOBCOPILOT_API_TOKEN=local-dev-token
OPENCLAW_SENDER_ALLOWLIST=

AUTH_REQUIRED=false
AUTH_TRUSTED_PROXY_SECRET=
AUTH_SIGNATURE_TTL_SECONDS=300
DEV_USER_EXTERNAL_ID=local-dev-user
DEV_USER_EMAIL=
DEV_USER_DISPLAY_NAME=Local Developer
DEV_USER_PLAN=free
DEV_USER_SUBSCRIPTION_STATUS=inactive

DATA_RETENTION_DAYS=
ENABLE_JOB_BROWSER_FALLBACK=true
JOB_BROWSER_TIMEOUT_MS=8000

AGENT_WORKFLOW_MODE=deterministic_fallback
LLM_PROVIDER=vertex
VERTEX_PROJECT_ID=
VERTEX_REGION=global
LLM_MODEL=gemini-3.5-flash
CREWAI_LLM_MODEL=

# Development/test defaults execute durable jobs inline so one API process is
# sufficient. Production should run `resumepilot-worker` and set this false.
WORKFLOW_INLINE_EXECUTION=true
WORKFLOW_WORKER_POLL_SECONDS=1
WORKFLOW_JOB_LEASE_SECONDS=180
WORKFLOW_JOB_MAX_ATTEMPTS=3
USAGE_RESERVATION_TTL_SECONDS=900
CREWAI_MAX_ITER=2
CREWAI_TIMEOUT_SECONDS=60
CREWAI_TEMPERATURE=0.2

LATEX_COMPILE_TIMEOUT_SECONDS=20
LATEX_PDF_MAX_BYTES=5242880
