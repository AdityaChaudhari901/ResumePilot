{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResumeProfile",
  "type": "object",
  "required": [
    "resume_id",
    "candidate",
    "skills",
    "facts"
  ],
  "properties": {
    "resume_id": {
      "type": "integer"
    },
    "candidate": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "links": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "category",
          "evidence_ids"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "experience": {
      "type": "array"
    },
    "projects": {
      "type": "array"
    },
    "education": {
      "type": "array"
    },
    "certifications": {
      "type": "array"
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "section"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "section": {
            "type": "string"
          }
        }
      }
    }
  }
}