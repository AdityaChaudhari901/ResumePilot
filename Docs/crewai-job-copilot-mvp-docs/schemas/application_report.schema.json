{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApplicationReport",
  "type": "object",
  "required": [
    "analysis_id",
    "match_score",
    "scoring_version",
    "score_status",
    "score_breakdown",
    "matched_skills",
    "missing_skills",
    "tailored_bullets",
    "cover_letter",
    "interview_questions",
    "validation_warnings"
  ],
  "properties": {
    "analysis_id": {
      "type": "integer"
    },
    "match_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "scoring_version": {
      "enum": [
        "legacy_unversioned",
        "deterministic_v1",
        "evidence_v2"
      ]
    },
    "score_status": {
      "enum": [
        "scored",
        "provisional"
      ]
    },
    "score_breakdown": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "scoring_version",
        "score_kind",
        "score_status",
        "uncapped_score",
        "score_cap",
        "total_score",
        "components"
      ],
      "properties": {
        "scoring_version": {
          "const": "evidence_v2"
        },
        "score_kind": {
          "const": "deterministic_evidence_fit"
        },
        "score_status": {
          "enum": [
            "scored",
            "provisional"
          ]
        },
        "uncapped_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "score_cap": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "total_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "components": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": {
            "type": "object",
            "required": [
              "key",
              "status",
              "score",
              "base_weight",
              "effective_weight",
              "contribution",
              "matched_count",
              "total_count",
              "evidence_ids",
              "explanation"
            ],
            "properties": {
              "key": {
                "enum": [
                  "required_skills",
                  "responsibilities",
                  "preferred_skills",
                  "experience",
                  "domain",
                  "evidence_strength"
                ]
              },
              "status": {
                "enum": [
                  "scored",
                  "unknown",
                  "not_applicable"
                ]
              },
              "score": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0,
                "maximum": 100
              },
              "base_weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "effective_weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "contribution": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "matched_count": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "total_count": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "evidence_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "explanation": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "matched_skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "skill",
          "match_type",
          "resume_evidence_ids",
          "job_evidence_text"
        ],
        "properties": {
          "skill": {
            "type": "string"
          },
          "match_type": {
            "enum": [
              "exact",
              "synonym",
              "inferred"
            ]
          },
          "resume_evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "job_evidence_text": {
            "type": "string"
          },
          "confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        }
      }
    },
    "missing_skills": {
      "type": "array"
    },
    "tailored_bullets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "bullet",
          "evidence_ids",
          "unsupported_claims"
        ],
        "properties": {
          "bullet": {
            "type": "string"
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "unsupported_claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "cover_letter": {
      "type": "string"
    },
    "interview_questions": {
      "type": "array"
    },
    "validation_warnings": {
      "type": "array"
    }
  }
}
