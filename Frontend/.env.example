RESUMEPILOT_API_BASE_URL=http://127.0.0.1:8000
RESUMEPILOT_AUTH_PROVIDER=local
# Keep false/blank for public deployments. Set true only for a private
# production-like stack where the single local dev user is intentional.
RESUMEPILOT_ALLOW_LOCAL_AUTH_IN_PRODUCTION=false

# Required when RESUMEPILOT_AUTH_PROVIDER is clerk or trusted_headers, and
# required when FastAPI runs with AUTH_REQUIRED=true. Also required for
# production local auth because the BFF signs tenant identity headers.
AUTH_TRUSTED_PROXY_SECRET=

# Required only for RESUMEPILOT_AUTH_PROVIDER=trusted_headers. This is distinct
# from AUTH_TRUSTED_PROXY_SECRET and verifies an upstream-issued HMAC before the
# BFF accepts x-resumepilot-auth-user/email/name. The upstream must also send
# x-resumepilot-upstream-auth-timestamp (Unix seconds) and
# x-resumepilot-upstream-auth-signature (HMAC-SHA256 over user, email, name,
# and timestamp separated by newlines).
RESUMEPILOT_TRUSTED_HEADER_SECRET=
RESUMEPILOT_TRUSTED_HEADER_TTL_SECONDS=300

DEV_USER_EXTERNAL_ID=local-dev-user
DEV_USER_EMAIL=
DEV_USER_DISPLAY_NAME=Local Developer

# Clerk's publishable key is intentionally browser-visible and is not a secret.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Server-only Clerk credential. Never expose this with a NEXT_PUBLIC_ prefix.
CLERK_SECRET_KEY=
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/
