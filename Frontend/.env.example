RESUMEPILOT_API_BASE_URL=http://127.0.0.1:8002
# local, clerk, or trusted_headers
RESUMEPILOT_AUTH_PROVIDER=local
# Shared HMAC secret used by the Next.js BFF and FastAPI when AUTH_REQUIRED=true.
AUTH_TRUSTED_PROXY_SECRET=
DEV_USER_EXTERNAL_ID=local-dev-user
DEV_USER_EMAIL=
DEV_USER_DISPLAY_NAME=Local Developer
# Clerk publishable key; safe to expose only when copied from your Clerk app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clerk backend secret key; never expose in client-side code.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/
OPENCLAW_PROVIDER=google-vertex
LLM_PROVIDER=vertex
VERTEX_PROJECT_ID=alien-slice-499511-f8
VERTEX_REGION=global
LLM_MODEL=gemini-3.5-flash
OPENCLAW_MODEL_REFERENCE=google-vertex/gemini-3.5-flash
